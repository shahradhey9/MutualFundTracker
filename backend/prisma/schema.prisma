generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  passwordHash String?  // null when using external auth (Clerk / Auth0)
  createdAt    DateTime @default(now())
  holdings     Holding[]
}

// Master fund catalogue (seeded + updated by sync job)
model FundMeta {
  id         String   @id // e.g. "IN-120503" or "US-VOO"
  region     Region
  name       String
  amc        String
  ticker     String   @unique
  schemeCode String?  // AMFI scheme code for Indian MFs
  isin       String?
  category   String?  // "Flexi Cap", "ETF - US Equity", etc.
  updatedAt  DateTime @updatedAt

  latestNav  Decimal? // denormalised for fast reads
  navDate    DateTime?

  holdings   Holding[]
  navHistory NavHistory[]

  @@index([region])
  @@index([name])
  @@index([amc])
}

model Holding {
  id         String   @id @default(uuid())
  userId     String
  fundId     String
  units      Decimal
  avgCost    Decimal? // per unit, in fund's native currency
  purchaseAt DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fund       FundMeta @relation(fields: [fundId], references: [id])

  @@unique([userId, fundId]) // auto-consolidation enforced at DB level
  @@index([userId])
}

// Immutable daily NAV log — used for XIRR / historical gain calc (V2)
model NavHistory {
  id       String   @id @default(uuid())
  fundId   String
  nav      Decimal
  navDate  DateTime @db.Date

  fund     FundMeta @relation(fields: [fundId], references: [id])

  @@unique([fundId, navDate])
  @@index([fundId, navDate])
}

enum Region {
  INDIA
  GLOBAL
}
